FROM maven:3.9.9-eclipse-temurin-17 AS build
WORKDIR /workspace
COPY . .
RUN mvn -q -DskipTests -pl telemetry-service -am package

FROM eclipse-temurin:17-jre
WORKDIR /app
COPY --from=build /workspace/telemetry-service/target/telemetry-service-0.1.0.jar app.jar
EXPOSE 8081
ENTRYPOINT ["java","-jar","/app/app.jar"]
